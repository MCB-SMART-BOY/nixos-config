// Niri 配置文件（Wayland 平铺窗口管理器）
// ~/.config/niri/config.kdl
// 由 Home Manager 管理：home/users/mcbnixos/files.nix

// ══════════════════════════════════════════════════════════════════
// 🖥️ 输出配置
// ══════════════════════════════════════════════════════════════════

// 建议删除特定 output 配置，让 Niri 自动检测
// 如果必须指定，请确保名称 (eDP-1) 是准确的（可通过 `niri msg outputs` 查看）
output "eDP-1" {
    mode "3200x2000@165.002"
    scale 2
    position x=0 y=0
}

output "DP-5" {
    mode "3840x2160@160.000"
    scale 2
    position x=-1920 y=-80
}

output "DP-1" {
    mode "3840x2160@160.000"
    scale 2
    position x=-1920 y=-80
}
// ══════════════════════════════════════════════════════════════════
// ⌨️ 输入配置
// ══════════════════════════════════════════════════════════════════

input {
    // 键盘布局与重复输入速度
    keyboard {
        xkb {
            layout "us"
            options "ctrl:swapcaps"
            // options "caps:escape" // 如果你是 Vim 用户，建议开启
        }
        repeat-delay 300
        repeat-rate 50
    }

    // 触控板配置（tap=轻触点击，dwt=打字时禁用触控板）
    touchpad {
        tap
        dwt
        natural-scroll
        accel-speed 0.2
        accel-profile "adaptive"
    }

    // 鼠标加速度
    mouse {
        accel-speed 0.0
        accel-profile "flat"
    }

    // 鼠标跟随聚焦
    focus-follows-mouse max-scroll-amount="0%"
}

// ══════════════════════════════════════════════════════════════════
// 🎨 布局配置
// ══════════════════════════════════════════════════════════════════

layout {
    // 窗口间距与居中策略
    background-color "transparent"
    gaps 6
    center-focused-column "always"

    // 常用列宽预设（快捷切换）
    preset-column-widths {
        proportion 0.30
        proportion 0.5
        proportion 0.70
    }

    default-column-width { proportion 1.0; }

    focus-ring {
        width 2
        active-color "#5eead4"     // Accent
        inactive-color "#2a3648"   // Border
    }

    border {
        off
    }

    shadow {
        on
        softness 36
        spread 4
        offset x=0 y=6
        color "#0b111b99"
    }
}

// ══════════════════════════════════════════════════════════════════
// 🧠 兼容性 / Noctalia
// ══════════════════════════════════════════════════════════════════

debug {
    // 允许通知动作激活窗口（Noctalia 通知中心）
    honor-xdg-activation-with-invalid-serial
}

// Noctalia 壁纸层（固定在 backdrop）
layer-rule {
    match namespace="^noctalia-wallpaper*"
    place-within-backdrop true
}

// ══════════════════════════════════════════════════════════════════
// 🖼️ 窗口装饰
// ══════════════════════════════════════════════════════════════════

// 禁用客户端自绘标题栏（统一外观）
prefer-no-csd

// ══════════════════════════════════════════════════════════════════
// ✨ 动画（优化版）
// ══════════════════════════════════════════════════════════════════

animations {
    // 全局动画速度（越小越快）
    slowdown 1.05

    workspace-switch {
        spring damping-ratio=0.9 stiffness=800 epsilon=0.0001
    }

    window-open {
        duration-ms 220
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 160
        curve "ease-out-quad"
    }

    horizontal-view-movement {
        spring damping-ratio=0.9 stiffness=750 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=0.9 stiffness=750 epsilon=0.0001
    }

    window-resize {
        spring damping-ratio=0.9 stiffness=750 epsilon=0.0001
    }

    config-notification-open-close {
        spring damping-ratio=0.6 stiffness=1000 epsilon=0.001
    }
}

// ══════════════════════════════════════════════════════════════════
// 📸 截图（Niri 原生）
// ══════════════════════════════════════════════════════════════════
// 注意：更高级的截图在下面的 Key Bindings 里配置了 grim+slurp

screenshot-path "~/Pictures/Screenshots/Screenshot_%Y-%m-%d_%H-%M-%S.png"

// ══════════════════════════════════════════════════════════════════
// 🚀 自启动
// ══════════════════════════════════════════════════════════════════

// niri-run 会补齐 PATH，避免找不到命令
spawn-at-startup "niri-run" "noctalia-shell"
spawn-at-startup "niri-run" "fcitx5" "-d" "-r" // -r 替换现有实例
spawn-at-startup "niri-run" "swayidle" "-w" "timeout" "300" "lock-screen" "timeout" "600" "niri" "msg" "action" "power-off-monitors" "before-sleep" "lock-screen"

// ══════════════════════════════════════════════════════════════════
// 🪟 窗口规则
// ══════════════════════════════════════════════════════════════════

window-rule {
    geometry-corner-radius 18
    clip-to-geometry true
}

window-rule {
    match app-id=r#"^(pavucontrol|org.keepassxc.KeePassXC)$"#
    open-floating true
}

window-rule {
    match app-id="firefox" title="Picture-in-Picture"
    open-floating true
}

// ══════════════════════════════════════════════════════════════════
// ⌨️ 快捷键
// ══════════════════════════════════════════════════════════════════

binds {
    // Mod 默认是 Super/Win 键（可在 niri 文档中调整）
    // ─── 应用启动 ───
    Mod+Return { spawn "niri-run" "alacritty"; }
    Mod+Space { spawn "niri-run" "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+E { spawn "niri-run" "nautilus"; }
    Mod+B { spawn "niri-run" "firefox"; }

    // ─── 系统控制 ───
    Mod+Q { close-window; }
    Mod+Shift+Q { quit; } // 退出 Niri 会话
    Mod+Shift+Slash { show-hotkey-overlay; }

    // 锁屏
    Mod+Escape { spawn "niri-run" "lock-screen"; }

    // 电源管理
    Mod+Shift+P { power-off-monitors; }
    // 壁纸交给 Noctalia 管理
    Mod+Shift+C { spawn "niri-run" "noctalia-shell" "ipc" "call" "wallpaper" "random"; }
    Mod+Shift+W { spawn "niri-run" "noctalia-shell" "ipc" "call" "wallpaper" "toggle"; }

    // ─── 焦点移动 (Vim 风格) ───
    Mod+h { focus-column-left; }
    Mod+Alt+j { focus-window-down; }
    Mod+Alt+k { focus-window-up; }
    Mod+l { focus-column-right; }

    Mod+Left { focus-column-left; }
    Mod+Down { focus-window-down; }
    Mod+Up { focus-window-up; }
    Mod+Right { focus-column-right; }

    // ─── 窗口移动 ───
    Mod+Shift+h { move-column-left; }
    Mod+Shift+j { move-window-down; }
    Mod+Shift+k { move-window-up; }
    Mod+Shift+l { move-column-right; }

    Mod+Shift+Left { move-column-left; }
    Mod+Shift+Down { move-window-down; }
    Mod+Shift+Up { move-window-up; }
    Mod+Shift+Right { move-column-right; }

    // ─── 快速跳转 ───
    Mod+Home { focus-column-first; }
    Mod+End { focus-column-last; }
    Mod+Shift+Home { move-column-to-first; }
    Mod+Shift+End { move-column-to-last; }

    // ─── 布局操作 ───
    // 把当前窗口吸入/弹出到相邻列（适合整理列结构）
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    // 在预设列宽之间循环切换
    Mod+R { switch-preset-column-width; }
    // 重置窗口高度（恢复默认比例）
    Mod+Shift+R { reset-window-height; }
    // 最大化当前列（纵向填满）
    Mod+Ctrl+F { maximize-column; }
    // 全屏当前窗口
    Mod+F { fullscreen-window; }
    // 把窗口扩展到边缘（不是真全屏）
    Mod+M { maximize-window-to-edges; }
    // 把焦点列居中显示
    Mod+C { center-column; }
    // 切换列内 Tab 显示（适合同一列多个窗口）
    Mod+W { toggle-column-tabbed-display; }

    Mod+Comma  { focus-monitor-previous; }
    Mod+Period { focus-monitor-next; }
    Mod+Shift+Period { move-window-to-monitor-next; }
    Mod+Shift+Comma { move-window-to-monitor-previous; }
    

    // 微调大小
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    // ─── 工作区 (Workspaces) ───
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    Mod+j { focus-workspace-down; }
    Mod+k { focus-workspace-up; }
    Mod+Grave { focus-workspace-previous; }
    Mod+Tab { toggle-overview; }
    Mod+Shift+Tab { focus-workspace-up; }
    // 鼠标滚轮切换工作区（带冷却避免过快）
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }

    // ─── 浮动窗口 ───
    // 把当前窗口从平铺切换为浮动（或反向）
    Mod+Shift+F { toggle-window-floating; }
    // 在浮动与平铺窗口之间切换焦点
    Mod+Shift+V { switch-focus-between-floating-and-tiling; }

    // ─── 截图（高级模式） ───
    // 依赖: grim, slurp, swappy (需在 systemPackages 中安装)
    // 截图全屏
    Print { spawn "niri-run" "mcbctl" "screenshot-edit" "full"; }
    // 截图选区 (推荐)
    Shift+Print { spawn "niri-run" "mcbctl" "screenshot-edit" "region"; }
    // 原生截图 (备用)
    Alt+Print { screenshot; }

    // ─── 媒体与亮度 ───
    XF86AudioRaiseVolume allow-when-locked=true { spawn "niri-run" "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "niri-run" "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "5%-"; }
    XF86AudioMute allow-when-locked=true { spawn "niri-run" "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute allow-when-locked=true { spawn "niri-run" "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }
    XF86MonBrightnessUp allow-when-locked=true { spawn "niri-run" "brightnessctl" "set" "5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "niri-run" "brightnessctl" "set" "5%-"; }
}
